{
  "name": "@pontistudios/hollywood-api",
  "version": "0.1.0",
  "private": true,
  "description": "Hollywood entertainment graph API — Hono REST + OpenAPI backed by hollywood.db",
  "bin": "./dist/index.js",
  "type": "module",
  "exports": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:refresh": "tsx src/scripts/refresh-db.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/zod-openapi": "^1.4.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^11.0.0",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "jsdom": "^29.1.1",
    "mailparser": "^3.9.14",
    "playwright": "^1.61.1",
    "rss-parser": "^3.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.3",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^0.9.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
