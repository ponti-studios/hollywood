{
  "name": "@pontistudios/hollywood-api",
  "version": "0.1.0",
  "private": true,
  "description": "Hollywood entertainment graph API — TypeScript GraphQL server backed by hollywood.db",
  "type": "module",
  "exports": "./dist/index.js",
  "bin": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
