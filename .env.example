# Copy this file to `.env` if you want to override the runtime defaults.
# Never commit `.env` to git.

# --- HuggingFace ---
# Required if you pull gated models locally or rebuild model images with a fresh cache.
HF_TOKEN=hf_your_token_here

# --- Weights & Biases ---
WANDB_PROJECT=nexus-posttraining
WANDB_API_KEY=your_wandb_key_here
WANDB_DISABLED=false

# --- Nexus runtime backends ---
# These default to the Docker Compose service names used by the repo.
# Override them only if you run the backend services on different hosts or ports.
NEXUS_TEXT_MODEL_ID=HuggingFaceTB/SmolLM2-135M-Instruct
NEXUS_TEXT_MODEL_URL=http://nexus-text:8080
NEXUS_TEXT_AUTOLOAD=true
NEXUS_AUDIO_TTS_URL=http://nexus-audio-tts:8001
NEXUS_AUDIO_ASR_URL=http://nexus-audio-asr:8002
