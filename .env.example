# Migrations (Goose)
GOOSE_DRIVER=sqlite3
GOOSE_DBSTRING=$HOME/.hominem/hollywood.db
GOOSE_MIGRATION_DIR=migrations

# API server
PORT=4000
HOST=0.0.0.0

# Storage
HOLLYWOOD_DATA_DIR=data
HOLLYWOOD_DB_PATH=~/.hominem/hollywood.db

# Ingest adapters
HOLLYWOOD_LOG_LEVEL=INFO
HOLLYWOOD_USER_AGENT=ResearchBot/0.2 contact@example.com
HOLLYWOOD_REQUEST_TIMEOUT_SECONDS=30
TMDB_API_KEY=

# LLM extraction (POST /ingest)
OPENROUTER_API_KEY=
