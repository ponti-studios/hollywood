# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# --- HuggingFace ---
# Required to download Gemma 3 (gated model — accept the license at huggingface.co/google/gemma-3-1b)
HF_TOKEN=hf_your_token_here

# --- Weights & Biases ---
# Sign up free at wandb.ai — used to track and compare training runs visually
WANDB_PROJECT=nexus-posttraining
WANDB_API_KEY=your_wandb_key_here

# Set to "true" to run without W&B tracking (useful for quick local tests)
WANDB_DISABLED=false
